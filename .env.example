# Database Configuration
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vishakan_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vishakan_db

# Security & JWT Token Configurations
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis & Celery Configuration
REDIS_URL=redis://localhost:6379/0

# Gemini API Key (required for LangChain and AI agronomist service)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# App Configuration
APP_NAME="Vishakan Biotech Smart Farming Assistant Backend"
DEBUG=true
PORT=8000
HOST=0.0.0.0
